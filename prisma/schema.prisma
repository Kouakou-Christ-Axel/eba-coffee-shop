// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  name  String?
  role  UserRole @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  image         String?
  sessions        Session[]
  accounts        Account[]
  createdOrders      Order[]        @relation("OrderCreatedBy")
  createdExpenses    Expense[]      @relation("ExpenseCreatedBy")
  createdInvestments Investment[]   @relation("InvestmentCreatedBy")
  revenueAdjustments RevenueAdjustment[] @relation("RevenueAdjustmentCreatedBy")
  cashClosings       CashClosing[]  @relation("CashClosingClosedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ─── OAuth (serveur MCP distant) ─────────────────────────────────────────────
//
// Tables du plugin MCP/OIDC de Better Auth (`lib/auth.ts`). Elles permettent à
// un client comme Claude (web/mobile) de se connecter au serveur `/api/mcp` via
// OAuth 2.0 : un administrateur s'authentifie avec SON compte, plutôt qu'avec un
// jeton statique partagé. Gérées par l'adaptateur Better Auth — ne pas écrire
// dessus à la main.

model OauthApplication {
  id           String   @id @default(cuid())
  name         String
  icon         String?
  metadata     String?
  clientId     String   @unique
  clientSecret String?
  redirectUrls String
  type         String
  disabled     Boolean  @default(false)
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("oauth_application")
}

model OauthAccessToken {
  id                    String   @id @default(cuid())
  accessToken           String   @unique
  refreshToken          String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  clientId              String
  userId                String?
  scopes                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_access_token")
}

model OauthConsent {
  id           String   @id @default(cuid())
  clientId     String
  userId       String
  scopes       String
  consentGiven Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_consent")
}

enum UserRole {
  USER
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DELIVERY
  DINE_IN
  TAKEAWAY
}

enum PaymentMode {
  CASH
  WAVE
  OTHER
}

model Order {
  id            String       @id @default(cuid())
  reference     String       @unique
  dailyDate     DateTime     @db.Date
  dailyNumber   Int
  customerName  String?
  customerPhone String?
  pickupTime    DateTime?
  orderType     OrderType    @default(TAKEAWAY)
  items         Json
  total         Int
  status        OrderStatus  @default(NEW)
  note          String?

  isPaid            Boolean      @default(false)
  paymentMode       PaymentMode?
  paidAt            DateTime?

  driverRequested   Boolean   @default(false)
  driverRequestedAt DateTime?

  createdById String?
  createdBy   User?   @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Client identifié par téléphone (CRM / fidélité). Null = commande anonyme.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyDate, dailyNumber])
  @@index([status, isPaid])
  @@index([createdAt(sort: Desc)])
  @@index([customerId])
  @@map("order")
}

model Customer {
  // Identité client (CRM). Clé = téléphone normalisé (forme canonique E.164
  // quand reconnu, sinon chiffres). Pas de compte/login : on identifie au numéro.
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?

  // Fidélité (carte à tampons). `stampCount` = avancement de la carte en cours.
  // `lastStampDate` sert à la règle « 1 tampon / jour / numéro ».
  stampCount    Int       @default(0)
  lastStampDate DateTime? @db.Date

  orders    Order[]
  rewards   LoyaltyReward[]
  ledger    LoyaltyLedger[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer")
}

enum LoyaltyRewardStatus {
  AVAILABLE
  USED
}

model LoyaltyReward {
  id         String              @id @default(cuid())
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier       Int // palier atteint (nb de tampons), ex. 5 ou 10
  capAmount  Int // plafond de la récompense (FCFA)
  status     LoyaltyRewardStatus @default(AVAILABLE)

  earnedOrderId String?
  usedOrderId   String?
  earnedAt      DateTime  @default(now())
  usedAt        DateTime?

  @@index([customerId, status])
  @@map("loyalty_reward")
}

enum LoyaltyEventType {
  STAMP_EARNED
  REWARD_EARNED
  REWARD_USED
  ADJUSTMENT
}

model LoyaltyLedger {
  id         String           @id @default(cuid())
  customerId String
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       LoyaltyEventType
  stamps     Int              @default(0) // delta de tampons (ex. +1, ou ajustement)
  orderId    String?
  actorId    String? // utilisateur à l'origine (null = automatique / en ligne)
  note       String?
  createdAt  DateTime         @default(now())

  @@index([customerId])
  @@map("loyalty_ledger")
}

model LoyaltySettings {
  id             String  @id @default("singleton")
  enabled        Boolean @default(true)
  minOrderAmount Int     @default(1000) // montant min (FCFA) pour gagner 1 tampon
  stampsPerCard  Int     @default(10) // taille de la carte (palier final)
  tier1Stamps    Int     @default(5) // palier intermédiaire
  tier1RewardCap Int     @default(1000) // plafond récompense palier intermédiaire
  tier2RewardCap Int     @default(2500) // plafond récompense palier final
  oneStampPerDay Boolean @default(true)
  updatedAt      DateTime @updatedAt

  @@map("loyalty_settings")
}

model MenuCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  available Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("menu_category")
}

model Product {
  id               String            @id @default(cuid())
  name             String
  description      String
  price            Int
  coutMatiere      Int               @default(0)
  coutEmballage    Int               @default(0)
  imageUrl         String?
  available        Boolean           @default(true)
  sortOrder        Int               @default(0)
  featured         Boolean           @default(false)
  featuredOrder    Int               @default(0)
  featuredBadge    String?
  categoryId       String
  category         MenuCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplementGroups SupplementGroup[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([featured, featuredOrder])
  @@map("product")
}

model SupplementGroup {
  id        String             @id @default(cuid())
  name      String
  type      String
  required  Boolean            @default(false)
  sortOrder Int                @default(0)
  productId String
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   SupplementOption[]

  @@map("supplement_group")
}

model SupplementOption {
  id      String          @id @default(cuid())
  name    String
  price   Int
  groupId String
  group   SupplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("supplement_option")
}

model PickupSettings {
  id              String   @id @default("singleton")
  slotIntervalMin Int      @default(15)
  leadTimeMin     Int      @default(30)
  visibleDays     Int      @default(2)
  capacityPerSlot Int?
  weeklyHours     Json     @default("{}")
  dateOverrides   Json     @default("[]")
  pickupAddress   String?
  pickupMapsUrl   String?
  updatedAt       DateTime @updatedAt

  @@map("pickup_settings")
}

enum ExpensePaymentMethod {
  CASH
  WAVE
  BANK
  OTHER
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  expenses  Expense[]
  recurring RecurringExpense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("expense_category")
}

// Modèle (template) de dépense récurrente : sert d'aide-mémoire. On alerte si
// aucune dépense de la même catégorie n'a été saisie dans le mois civil courant
// (loyer, abonnements, salaires…). Ne crée pas de dépense automatiquement.
model RecurringExpense {
  id             String          @id @default(cuid())
  label          String // ex. « Loyer », « Internet »
  categoryId     String
  category       ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expectedAmount Int? // montant indicatif (FCFA)
  dayOfMonth     Int? // jour du mois indicatif (1-31)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@map("recurring_expense")
}

model Expense {
  id            String               @id @default(cuid())
  // Jour civil de la dépense (cohérent avec Order.dailyDate pour les requêtes
  // de plage dans les stats).
  date          DateTime             @db.Date
  amount        Int // montant en francs CFA
  paymentMethod ExpensePaymentMethod @default(CASH)
  supplier      String?
  note          String?
  // Justificatif (photo) optionnel : chemin /uploads/receipts/... ou URL http(s).
  receiptUrl    String?

  // Numéro de reçu séquentiel, attribué à la création et IMMUABLE (principe
  // comptable : un document numéroté ne change pas, même si on modifie sa date).
  // Le compteur (receiptSeq) est remis à zéro chaque mois civil, scopé par
  // receiptPeriod ("YYYY-MM" du mois d'attribution). receiptNo est le libellé
  // formaté affiché/exporté : DEP-YYYY-MM-NNNN (ex. DEP-2026-06-0001).
  receiptNo     String  @unique
  receiptPeriod String // mois d'attribution "YYYY-MM"
  receiptSeq    Int // séquence dans le mois (1-based)

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receiptPeriod, receiptSeq])
  @@index([date(sort: Desc)])
  @@index([categoryId])
  @@map("expense")
}

model CashClosing {
  id          String   @id @default(cuid())
  // Un jour civil = une clôture (cohérent avec Order.dailyDate / Expense.date).
  date        DateTime @unique @db.Date
  openingFloat Int     @default(0) // fond de caisse (FCFA)
  countedCash  Int     @default(0) // espèces comptées en fin de journée

  // Instantané calculé au moment de la clôture (les commandes/dépenses peuvent
  // évoluer ensuite — on fige ce que le système indiquait).
  cashSales    Int @default(0) // ventes encaissées en espèces ce jour
  cashExpenses Int @default(0) // dépenses payées en espèces ce jour
  expectedCash Int @default(0) // openingFloat + cashSales - cashExpenses
  difference   Int @default(0) // countedCash - expectedCash

  note String?

  closedById String?
  closedBy   User?   @relation("CashClosingClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("cash_closing")
}

// ─── Investissements (apports / financements) ──────────────────────────────────
// Distincts des dépenses d'exploitation : argent INJECTÉ dans l'affaire (capital
// propre, prêt, apport d'associé, subvention…). On suit la source de financement
// et, pour les apports remboursables, un suivi de remboursement léger
// (montant remboursé / restant dû calculé). N'impacte PAS la marge nette.

enum InvestmentPaymentMethod {
  CASH
  WAVE
  BANK
  OTHER
}

model InvestmentSource {
  id          String       @id @default(cuid())
  name        String       @unique
  sortOrder   Int          @default(0)
  investments Investment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("investment_source")
}

model Investment {
  id            String                  @id @default(cuid())
  // Jour civil de l'apport (cohérent avec Order.dailyDate / Expense.date).
  date          DateTime                @db.Date
  amount        Int // montant injecté, en francs CFA
  paymentMethod InvestmentPaymentMethod @default(CASH) // canal d'entrée des fonds
  financier     String? // nom du financeur (associé, banque…)
  note          String?
  // Justificatif optionnel : chemin /uploads/receipts/... ou URL http(s).
  documentUrl   String?

  // Suivi de remboursement léger. `reimbursable` = false → apport non remboursable
  // (capital, subvention). Restant dû = amount - amountRepaid (calculé, jamais stocké).
  reimbursable Boolean   @default(false)
  amountRepaid Int       @default(0) // cumul déjà remboursé (FCFA)
  dueDate      DateTime? @db.Date // échéance indicative (optionnelle)

  sourceId String
  source   InvestmentSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("InvestmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@index([sourceId])
  @@map("investment")
}

// ─── Régularisation de recette (ajustement manuel du CA) ───────────────────────
// Permet d'enregistrer un montant de CA SANS commande (ventes non saisies en
// temps réel, anciennes commandes perdues…). Injecté dans lib/stats.ts → remonte
// dans les statistiques, la série journalière et la clôture de caisse (mode
// espèces). Réutilise l'enum PaymentMode (cohérent avec les commandes).

model RevenueAdjustment {
  id          String      @id @default(cuid())
  // Jour civil de la recette (cohérent avec Order.dailyDate / Expense.date).
  date        DateTime    @db.Date
  amount      Int // FCFA, SIGNÉ : + = recette ajoutée, − = recette retirée
  paymentMode PaymentMode @default(CASH) // canal (alimente la clôture si CASH)
  note        String? // motif de la régularisation

  createdById String?
  createdBy   User?   @relation("RevenueAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("revenue_adjustment")
}

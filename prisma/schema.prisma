// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  name  String?
  role  UserRole @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  image         String?
  sessions        Session[]
  accounts        Account[]
  createdOrders      Order[]        @relation("OrderCreatedBy")
  createdExpenses    Expense[]      @relation("ExpenseCreatedBy")
  createdInvestments Investment[]   @relation("InvestmentCreatedBy")
  revenueAdjustments RevenueAdjustment[] @relation("RevenueAdjustmentCreatedBy")
  cashClosings       CashClosing[]  @relation("CashClosingClosedBy")
  inventoryPurchasesCreated InventoryPurchase[]     @relation("InventoryPurchaseCreatedBy")
  inventoryCountsCreated    InventoryCount[]        @relation("InventoryCountCreatedBy")
  restockBatchesCreated     InventoryRestockBatch[] @relation("RestockBatchCreatedBy")
  pushSubscriptions         PushSubscription[]
  createdPolls              Poll[]             @relation("PollCreatedBy")
  moderatedPollSuggestions  PollSuggestion[]   @relation("PollSuggestionModeratedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ─── OAuth (serveur MCP distant) ─────────────────────────────────────────────
//
// Tables du plugin MCP/OIDC de Better Auth (`lib/auth.ts`). Elles permettent à
// un client comme Claude (web/mobile) de se connecter au serveur `/api/mcp` via
// OAuth 2.0 : un administrateur s'authentifie avec SON compte, plutôt qu'avec un
// jeton statique partagé. Gérées par l'adaptateur Better Auth — ne pas écrire
// dessus à la main.

model OauthApplication {
  id           String   @id @default(cuid())
  name         String
  icon         String?
  metadata     String?
  clientId     String   @unique
  clientSecret String?
  redirectUrls String
  type         String
  disabled     Boolean  @default(false)
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("oauth_application")
}

model OauthAccessToken {
  id                    String   @id @default(cuid())
  accessToken           String   @unique
  refreshToken          String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  clientId              String
  userId                String?
  scopes                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_access_token")
}

model OauthConsent {
  id           String   @id @default(cuid())
  clientId     String
  userId       String
  scopes       String
  consentGiven Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_consent")
}

enum UserRole {
  USER
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DELIVERY
  DINE_IN
  TAKEAWAY
}

enum PaymentMode {
  CASH
  WAVE
  OTHER
}

model Order {
  id            String       @id @default(cuid())
  reference     String       @unique
  dailyDate     DateTime     @db.Date
  dailyNumber   Int
  customerName  String?
  customerPhone String?
  pickupTime    DateTime?
  orderType     OrderType    @default(TAKEAWAY)
  items         Json
  total         Int
  status        OrderStatus  @default(NEW)
  note          String?

  isPaid            Boolean      @default(false)
  paymentMode       PaymentMode?
  paidAt            DateTime?

  driverRequested   Boolean   @default(false)
  driverRequestedAt DateTime?

  // Livreur envoyé par le client (renseigné/modifiable depuis la page de suivi).
  driverName  String?
  driverPhone String?

  // Preuve de paiement (capture Wave) uploadée par le client
  // (/uploads/payment-proofs/…). Validée manuellement en caisse.
  paymentProofUrl String?

  createdById String?
  createdBy   User?   @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Client identifié par téléphone (CRM / fidélité). Null = commande anonyme.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Appareils clients abonnés aux changements de statut (page de suivi).
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyDate, dailyNumber])
  @@index([status, isPaid])
  @@index([createdAt(sort: Desc)])
  @@index([customerId])
  @@map("order")
}

model Customer {
  // Identité client (CRM). Clé = téléphone normalisé (forme canonique E.164
  // quand reconnu, sinon chiffres). Pas de compte/login : on identifie au numéro.
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?

  // Fidélité (carte à tampons). `stampCount` = avancement de la carte en cours.
  // `lastStampDate` sert à la règle « 1 tampon / jour / numéro ».
  stampCount    Int       @default(0)
  lastStampDate DateTime? @db.Date

  orders    Order[]
  rewards   LoyaltyReward[]
  ledger    LoyaltyLedger[]
  pollVotes PollVote[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer")
}

enum LoyaltyRewardStatus {
  AVAILABLE
  USED
}

model LoyaltyReward {
  id         String              @id @default(cuid())
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier       Int // palier atteint (nb de tampons), ex. 5 ou 10
  capAmount  Int // plafond de la récompense (FCFA)
  status     LoyaltyRewardStatus @default(AVAILABLE)

  earnedOrderId String?
  usedOrderId   String?
  earnedAt      DateTime  @default(now())
  usedAt        DateTime?

  @@index([customerId, status])
  @@map("loyalty_reward")
}

enum LoyaltyEventType {
  STAMP_EARNED
  REWARD_EARNED
  REWARD_USED
  ADJUSTMENT
}

model LoyaltyLedger {
  id         String           @id @default(cuid())
  customerId String
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       LoyaltyEventType
  stamps     Int              @default(0) // delta de tampons (ex. +1, ou ajustement)
  orderId    String?
  actorId    String? // utilisateur à l'origine (null = automatique / en ligne)
  note       String?
  createdAt  DateTime         @default(now())

  @@index([customerId])
  @@map("loyalty_ledger")
}

model LoyaltySettings {
  id             String  @id @default("singleton")
  enabled        Boolean @default(true)
  minOrderAmount Int     @default(1000) // montant min (FCFA) pour gagner 1 tampon
  stampsPerCard  Int     @default(10) // taille de la carte (palier final)
  tier1Stamps    Int     @default(5) // palier intermédiaire
  tier1RewardCap Int     @default(1000) // plafond récompense palier intermédiaire
  tier2RewardCap Int     @default(2500) // plafond récompense palier final
  oneStampPerDay Boolean @default(true)
  updatedAt      DateTime @updatedAt

  @@map("loyalty_settings")
}

// ─── Sondages (moteur générique de vote) ───────────────────────────────────────
// Permet de sonder les clients sur n'importe quel sujet. Premier cas d'usage :
// choisir la pâtisserie de la semaine parmi des suggestions de la communauté,
// modérées par un admin avant de devenir des options de vote. Le site public
// n'a pas de compte client : le votant est identifié soit par téléphone
// (clé normalisée, comme Customer.phone), soit par un token anonyme
// (cookie/localStorage) si aucun téléphone n'est fourni — voir PollVote.
// Indépendant de la fidélité (lib/loyalty*) dans cette version.

enum PollStatus {
  DRAFT // en préparation (peut déjà collecter des suggestions), pas encore public
  OPEN // vote ouvert
  CLOSED // clôturé, résultats figés
}

enum PollResultsVisibility {
  LIVE // résultats visibles publiquement pendant le vote
  AFTER_CLOSE // résultats visibles seulement une fois le sondage CLOSED
}

enum PollSuggestionStatus {
  PENDING
  APPROVED // promue en PollOption
  REJECTED
}

model Poll {
  id          String     @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  status      PollStatus @default(DRAFT)
  // Si vrai, la page publique du sondage propose « proposer une pâtisserie »
  // (ou tout autre type d'option) — indépendant du statut : on peut collecter
  // des suggestions pendant que le sondage est encore en préparation (DRAFT).
  allowSuggestions  Boolean               @default(false)
  resultsVisibility PollResultsVisibility @default(AFTER_CLOSE)
  // Fenêtre indicative (pas de tâche planifiée dans ce repo pour clôturer
  // automatiquement) : à vérifier côté lecture/vote (`closesAt < now()`), le
  // passage réel en CLOSED reste une action explicite (dashboard/MCP).
  opensAt  DateTime?
  closesAt DateTime?

  createdById String?
  createdBy   User?   @relation("PollCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  options     PollOption[]
  votes       PollVote[]
  suggestions PollSuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("poll")
}

model PollOption {
  id          String  @id @default(cuid())
  pollId      String
  poll        Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label       String
  description String?
  imageUrl    String?
  sortOrder   Int     @default(0)
  // Soft delete : les votes déjà enregistrés référencent l'option, on ne peut
  // pas la supprimer physiquement une fois le sondage ouvert.
  deletedAt DateTime?

  // Traçabilité : option créée par promotion d'une suggestion approuvée.
  sourceSuggestionId String?         @unique
  sourceSuggestion   PollSuggestion? @relation("SuggestionPromotedTo", fields: [sourceSuggestionId], references: [id], onDelete: SetNull)

  votes PollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pollId, deletedAt])
  @@map("poll_option")
}

model PollVote {
  id       String     @id @default(cuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  // Dédup « forte » : téléphone normalisé (même clé que Customer.phone).
  // Null si vote anonyme par token.
  voterPhone String?
  // Lien CRM optionnel si le téléphone correspond/est promu à un Customer
  // (miroir de Order.customerId — jamais requis).
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Dédup « faible » : token anonyme (uuid généré côté client, stocké en
  // localStorage). Null si vote identifié par téléphone.
  voterToken String?

  ipAddress String? // best-effort, aide à la modération anti-abus
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Un bulletin par (sondage, téléphone) ET indépendamment un par (sondage,
  // token) : Postgres traite NULL comme distinct dans un index unique, donc
  // chaque contrainte ne s'applique qu'aux lignes où la colonne est
  // renseignée (un vote « téléphone » et un vote « anonyme » ne se gênent
  // jamais). Revote autorisé tant que le sondage est OPEN via upsert sur
  // cette clé plutôt qu'un insert bloquant.
  @@unique([pollId, voterPhone])
  @@unique([pollId, voterToken])
  @@index([pollId, optionId])
  @@index([customerId])
  @@map("poll_vote")
}

model PollSuggestion {
  id          String               @id @default(cuid())
  pollId      String
  poll        Poll                 @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label       String
  description String?
  imageUrl    String?
  status      PollSuggestionStatus @default(PENDING)

  submitterPhone String? // normalisé, comme Customer.phone
  submitterName  String?

  moderatedById   String?
  moderatedBy     User?     @relation("PollSuggestionModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)
  moderatedAt     DateTime?
  rejectionReason String?

  promotedOption PollOption? @relation("SuggestionPromotedTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pollId, status])
  @@map("poll_suggestion")
}

model MenuCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  available Boolean   @default(true)
  // Soft delete : `deletedAt` non nul = catégorie « supprimée » (masquée partout
  // mais conservée en base, ainsi que ses produits). Le `slug` est dé-collisionné
  // à la suppression pour pouvoir réutiliser le même nom ensuite.
  deletedAt DateTime?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt])
  @@map("menu_category")
}

model Product {
  id               String            @id @default(cuid())
  name             String
  description      String
  price            Int
  coutMatiere      Int               @default(0)
  coutEmballage    Int               @default(0)
  imageUrl         String?
  available        Boolean           @default(true)
  sortOrder        Int               @default(0)
  featured         Boolean           @default(false)
  featuredOrder    Int               @default(0)
  featuredBadge    String?
  // Stock vendable courant. `null` = illimité (comportement historique,
  // jamais suivi ni bloqué) ; entier = quantité restante suivie ; `0` = épuisé
  // (le produit reste visible côté public mais non commandable).
  stockQuantity    Int?
  // Pause programmée : produit non commandable jusqu'à cette date-heure (mais
  // toujours visible, avec un tag de statut). `null` = pas de pause. La reprise
  // est calculée à la lecture (comparaison à `now`), sans job cron.
  unavailableUntil DateTime?
  // Soft delete : `deletedAt` non nul = produit « supprimé » (masqué partout mais
  // conservé). Posé aussi en cascade quand sa catégorie est supprimée.
  deletedAt        DateTime?
  categoryId       String
  category         MenuCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplementGroups SupplementGroup[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([featured, featuredOrder])
  @@index([deletedAt])
  @@map("product")
}

model SupplementGroup {
  id        String             @id @default(cuid())
  name      String
  // 'single' (un choix), 'multiple' (cases à cocher) ou 'quantity' (répartition
  // d'une quantité totale entre les options, ex. 3 parts à répartir sur 3 goûts).
  type      String
  required  Boolean            @default(false)
  sortOrder Int                @default(0)
  // Disponibilité : un groupe désactivé reste configuré mais n'est plus proposé
  // côté client (ni en caisse). Permet de masquer temporairement tout un groupe.
  available Boolean            @default(true)
  // Bornes sur le nombre de sélections (type 'multiple' : nombre d'options
  // cochées) ou sur la quantité totale répartie (type 'quantity'). `null` =
  // pas de borne. Ignorées pour le type 'single' (toujours 0 ou 1, régi par
  // `required`).
  minSelect Int?
  maxSelect Int?
  productId String
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   SupplementOption[]

  @@map("supplement_group")
}

model SupplementOption {
  id      String          @id @default(cuid())
  name    String
  price   Int
  // Disponibilité d'un « goût » : désactivé = conservé mais non sélectionnable.
  available Boolean       @default(true)
  // Stock vendable courant de cette option. `null` = illimité ; entier = suivi ;
  // `0` = épuisé (grisé côté public, mais l'option reste listée). Même sémantique
  // que `Product.stockQuantity`.
  stockQuantity Int?
  groupId String
  group   SupplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("supplement_option")
}

model PickupSettings {
  id              String   @id @default("singleton")
  slotIntervalMin Int      @default(15)
  leadTimeMin     Int      @default(30)
  visibleDays     Int      @default(2)
  capacityPerSlot Int?
  weeklyHours     Json     @default("{}")
  dateOverrides   Json     @default("[]")
  pickupAddress   String?
  pickupMapsUrl   String?
  updatedAt       DateTime @updatedAt

  @@map("pickup_settings")
}

enum ExpensePaymentMethod {
  CASH
  WAVE
  BANK
  OTHER
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  // Soft delete : `deletedAt` non nul = catégorie « supprimée » (retirée des
  // listes/sélecteurs) mais conservée — les dépenses rattachées gardent leur
  // libellé. Recréer une catégorie du même nom « ressuscite » la version
  // supprimée (le nom reste unique).
  deletedAt DateTime?
  expenses  Expense[]
  recurring RecurringExpense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt])
  @@map("expense_category")
}

// Modèle (template) de dépense récurrente : sert d'aide-mémoire. On alerte si
// aucune dépense de la même catégorie n'a été saisie dans le mois civil courant
// (loyer, abonnements, salaires…). Ne crée pas de dépense automatiquement.
model RecurringExpense {
  id             String          @id @default(cuid())
  label          String // ex. « Loyer », « Internet »
  categoryId     String
  category       ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expectedAmount Int? // montant indicatif (FCFA)
  dayOfMonth     Int? // jour du mois indicatif (1-31)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@map("recurring_expense")
}

model Expense {
  id            String               @id @default(cuid())
  // Jour civil de la dépense (cohérent avec Order.dailyDate pour les requêtes
  // de plage dans les stats).
  date          DateTime             @db.Date
  amount        Int // montant en francs CFA
  paymentMethod ExpensePaymentMethod @default(CASH)
  supplier      String?
  note          String?
  // Justificatif (photo) optionnel : chemin /uploads/receipts/... ou URL http(s).
  receiptUrl    String?

  // Numéro de reçu séquentiel, attribué à la création et IMMUABLE (principe
  // comptable : un document numéroté ne change pas, même si on modifie sa date).
  // Le compteur (receiptSeq) est remis à zéro chaque mois civil, scopé par
  // receiptPeriod ("YYYY-MM" du mois d'attribution). receiptNo est le libellé
  // formaté affiché/exporté : DEP-YYYY-MM-NNNN (ex. DEP-2026-06-0001).
  // Nullable pour permettre un `db push` sans valeur par défaut sur les lignes
  // existantes ; les dépenses déjà en base sont numérotées via le script de
  // backfill (`pnpm db:backfill-expense-receipts`). Toute dépense créée par
  // l'app reçoit toujours son numéro.
  receiptNo     String? @unique
  receiptPeriod String? // mois d'attribution "YYYY-MM"
  receiptSeq    Int? // séquence dans le mois (1-based)

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Liens depuis l'inventaire : une dépense peut matérialiser un réappro
  // (achats de matières premières). Relation inverse, posée par le module stock.
  inventoryPurchases InventoryPurchase[]     @relation("ExpenseInventoryPurchases")
  restockBatches     InventoryRestockBatch[] @relation("ExpenseRestockBatch")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receiptPeriod, receiptSeq])
  @@index([date(sort: Desc)])
  @@index([categoryId])
  @@map("expense")
}

model CashClosing {
  id          String   @id @default(cuid())
  // Un jour civil = une clôture (cohérent avec Order.dailyDate / Expense.date).
  date        DateTime @unique @db.Date
  openingFloat Int     @default(0) // fond de caisse (FCFA)
  countedCash  Int     @default(0) // espèces comptées en fin de journée

  // Instantané calculé au moment de la clôture (les commandes/dépenses peuvent
  // évoluer ensuite — on fige ce que le système indiquait).
  cashSales    Int @default(0) // ventes encaissées en espèces ce jour
  cashExpenses Int @default(0) // dépenses payées en espèces ce jour
  expectedCash Int @default(0) // openingFloat + cashSales - cashExpenses
  difference   Int @default(0) // countedCash - expectedCash

  note String?

  closedById String?
  closedBy   User?   @relation("CashClosingClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("cash_closing")
}

// ─── Investissements (apports / financements) ──────────────────────────────────
// Distincts des dépenses d'exploitation : argent INJECTÉ dans l'affaire (capital
// propre, prêt, apport d'associé, subvention…). On suit la source de financement
// et, pour les apports remboursables, un suivi de remboursement léger
// (montant remboursé / restant dû calculé). N'impacte PAS la marge nette.

enum InvestmentPaymentMethod {
  CASH
  WAVE
  BANK
  OTHER
}

model InvestmentSource {
  id          String       @id @default(cuid())
  name        String       @unique
  sortOrder   Int          @default(0)
  // Soft delete : voir ExpenseCategory. Retirée des sélecteurs mais conservée ;
  // recréer une source du même nom ressuscite la version supprimée.
  deletedAt   DateTime?
  investments Investment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([deletedAt])
  @@map("investment_source")
}

model Investment {
  id            String                  @id @default(cuid())
  // Jour civil de l'apport (cohérent avec Order.dailyDate / Expense.date).
  date          DateTime                @db.Date
  amount        Int // montant injecté, en francs CFA
  paymentMethod InvestmentPaymentMethod @default(CASH) // canal d'entrée des fonds
  financier     String? // nom du financeur (associé, banque…)
  note          String?
  // Justificatif optionnel : chemin /uploads/receipts/... ou URL http(s).
  documentUrl   String?

  // Suivi de remboursement léger. `reimbursable` = false → apport non remboursable
  // (capital, subvention). Restant dû = amount - amountRepaid (calculé, jamais stocké).
  reimbursable Boolean   @default(false)
  amountRepaid Int       @default(0) // cumul déjà remboursé (FCFA)
  dueDate      DateTime? @db.Date // échéance indicative (optionnelle)

  sourceId String
  source   InvestmentSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("InvestmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@index([sourceId])
  @@map("investment")
}

// ─── Régularisation de recette (ajustement manuel du CA) ───────────────────────
// Permet d'enregistrer un montant de CA SANS commande (ventes non saisies en
// temps réel, anciennes commandes perdues…). Injecté dans lib/stats.ts → remonte
// dans les statistiques, la série journalière et la clôture de caisse (mode
// espèces). Réutilise l'enum PaymentMode (cohérent avec les commandes).

model RevenueAdjustment {
  id          String      @id @default(cuid())
  // Jour civil de la recette (cohérent avec Order.dailyDate / Expense.date).
  date        DateTime    @db.Date
  amount      Int // FCFA, SIGNÉ : + = recette ajoutée, − = recette retirée
  paymentMode PaymentMode @default(CASH) // canal (alimente la clôture si CASH)
  note        String? // motif de la régularisation

  createdById String?
  createdBy   User?   @relation("RevenueAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("revenue_adjustment")
}

// ─── Inventaire (matières premières & consommables) ────────────────────────────
// Suivi de stock PÉRIODIQUE (inventaire intermittent) de références indépendantes
// du menu (grains, lait, gobelets, sirops…). On enregistre un comptage physique
// par période ; le système déduit la consommation (= stock initial + achats −
// stock final). Les achats portent fournisseur + coût unitaire → prix moyen
// pondéré (PMP). Quantités en Decimal (kg/L fractionnaires), montants en Int FCFA.

enum InventoryUnit {
  UNIT // unité / pièce
  KG
  G
  L
  ML
  BOX // carton / lot
}

enum InventoryBatchSource {
  MANUAL // saisie manuelle (grille réappro)
  IMPORT // import Excel
}

// La référence stockable. `currentQuantity` et `avgUnitCost` (PMP) sont
// dénormalisés et maintenus dans la même transaction que les achats/comptages
// (les tables purchase/countLine restent la source d'audit).
model InventoryItem {
  id              String        @id @default(cuid())
  sku             String        @unique // clé d'upsert à l'import
  name            String
  category        String?
  unit            InventoryUnit @default(UNIT)
  currentQuantity Decimal       @default(0) @db.Decimal(12, 3) // dernier comptage + achats depuis
  avgUnitCost     Int           @default(0) // prix moyen pondéré (FCFA)
  safetyStock     Decimal       @default(0) @db.Decimal(12, 3)
  reorderPoint    Decimal?      @db.Decimal(12, 3)
  supplier        String?
  notes           String?
  active          Boolean       @default(true)
  lastCountedAt   DateTime?     @db.Date

  purchases  InventoryPurchase[]
  countLines InventoryCountLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, category])
  @@index([name])
  @@map("inventory_item")
}

// Lot de réappro : regroupe les achats d'une même opération (saisie ou import)
// pour permettre une annulation en une fois. `expenseId` = dépense auto-créée.
model InventoryRestockBatch {
  id          String               @id @default(cuid())
  date        DateTime             @db.Date
  supplier    String?
  note        String?
  source      InventoryBatchSource @default(MANUAL)
  expenseId   String?
  expense     Expense?             @relation("ExpenseRestockBatch", fields: [expenseId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?                @relation("RestockBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  canceledAt  DateTime?
  createdAt   DateTime             @default(now())

  purchases InventoryPurchase[]

  @@index([date(sort: Desc)])
  @@map("inventory_restock_batch")
}

// Une entrée (achat) : ligne d'un lot de réappro.
model InventoryPurchase {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date      DateTime      @db.Date
  quantity  Decimal       @db.Decimal(12, 3)
  unitCost  Int // coût unitaire à l'achat (FCFA)
  totalCost Int // quantity * unitCost (FCFA, arrondi)
  supplier  String?
  note      String?

  batchId String?
  batch   InventoryRestockBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  expenseId String?
  expense   Expense? @relation("ExpenseInventoryPurchases", fields: [expenseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("InventoryPurchaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([itemId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([batchId])
  @@index([expenseId])
  @@map("inventory_purchase")
}

// Session de comptage périodique (= « enregistrer l'inventaire »).
model InventoryCount {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  label       String?
  note        String?
  createdById String?
  createdBy   User?    @relation("InventoryCountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  lines InventoryCountLine[]

  @@index([date(sort: Desc)])
  @@map("inventory_count")
}

// Ligne de comptage : fige le calcul entrées/sorties de la période pour un item.
model InventoryCountLine {
  id                String         @id @default(cuid())
  countId           String
  count             InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  itemId            String
  item              InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  openingQuantity   Decimal        @db.Decimal(12, 3) // comptage précédent (snapshot), 0 si premier
  purchasesQuantity Decimal        @db.Decimal(12, 3) // achats entre les 2 comptages (snapshot)
  countedQuantity   Decimal        @db.Decimal(12, 3) // saisie physique
  consumption       Decimal        @db.Decimal(12, 3) // = opening + purchases − counted (figé)
  unitCostSnapshot  Int // PMP au moment du comptage (valorisation)

  @@unique([countId, itemId])
  @@index([itemId])
  @@map("inventory_count_line")
}

// Réglages d'inventaire (singleton) : rappel email si pas de comptage depuis N jours.
model InventorySettings {
  id                 String    @id @default("singleton")
  reminderDays       Int       @default(7)
  reminderEnabled    Boolean   @default(true)
  lastReminderSentAt DateTime?
  updatedAt          DateTime  @updatedAt

  @@map("inventory_settings")
}

// ─── Notifications push (backoffice + client) ──────────────────────────────────
// Un abonnement Web Push par navigateur/appareil (PushSubscription API), à
// double usage exclusif :
//   - `userId` renseigné  → appareil STAFF (nouvelles commandes, prêtes) ;
//   - `orderId` renseigné → appareil CLIENT suivant UNE commande (changements
//     de statut, page publique de suivi — capability URL).
// `endpoint` est unique (identifie l'abonnement côté navigateur) : un même
// appareil qui se réabonne (autre commande, autre compte) bascule simplement
// d'usage. `p256dh`/`auth` sont les clés de chiffrement requises par `web-push`.
// Nettoyé automatiquement (lib/push-notify.ts) quand le navigateur renvoie
// 404/410 (abonnement expiré), et à la fin de vie de la commande suivie.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@map("push_subscription")
}

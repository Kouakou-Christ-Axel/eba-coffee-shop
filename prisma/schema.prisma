// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  name  String?
  role  UserRole @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  image         String?
  sessions        Session[]
  accounts        Account[]
  createdOrders   Order[]        @relation("OrderCreatedBy")
  createdExpenses Expense[]      @relation("ExpenseCreatedBy")
  cashClosings    CashClosing[]  @relation("CashClosingClosedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

enum UserRole {
  USER
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DELIVERY
  DINE_IN
  TAKEAWAY
}

enum PaymentMode {
  CASH
  WAVE
  OTHER
}

model Order {
  id            String       @id @default(cuid())
  reference     String       @unique
  dailyDate     DateTime     @db.Date
  dailyNumber   Int
  customerName  String?
  customerPhone String?
  pickupTime    DateTime?
  orderType     OrderType    @default(TAKEAWAY)
  items         Json
  total         Int
  status        OrderStatus  @default(NEW)
  note          String?

  isPaid            Boolean      @default(false)
  paymentMode       PaymentMode?
  paidAt            DateTime?

  driverRequested   Boolean   @default(false)
  driverRequestedAt DateTime?

  createdById String?
  createdBy   User?   @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyDate, dailyNumber])
  @@index([status, isPaid])
  @@index([createdAt(sort: Desc)])
  @@map("order")
}

model MenuCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  available Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("menu_category")
}

model Product {
  id               String            @id @default(cuid())
  name             String
  description      String
  price            Int
  coutMatiere      Int               @default(0)
  coutEmballage    Int               @default(0)
  imageUrl         String?
  available        Boolean           @default(true)
  sortOrder        Int               @default(0)
  featured         Boolean           @default(false)
  featuredOrder    Int               @default(0)
  featuredBadge    String?
  categoryId       String
  category         MenuCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplementGroups SupplementGroup[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([featured, featuredOrder])
  @@map("product")
}

model SupplementGroup {
  id        String             @id @default(cuid())
  name      String
  type      String
  required  Boolean            @default(false)
  sortOrder Int                @default(0)
  productId String
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   SupplementOption[]

  @@map("supplement_group")
}

model SupplementOption {
  id      String          @id @default(cuid())
  name    String
  price   Int
  groupId String
  group   SupplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("supplement_option")
}

model PickupSettings {
  id              String   @id @default("singleton")
  slotIntervalMin Int      @default(15)
  leadTimeMin     Int      @default(30)
  visibleDays     Int      @default(2)
  capacityPerSlot Int?
  weeklyHours     Json     @default("{}")
  dateOverrides   Json     @default("[]")
  pickupAddress   String?
  pickupMapsUrl   String?
  updatedAt       DateTime @updatedAt

  @@map("pickup_settings")
}

enum ExpensePaymentMethod {
  CASH
  WAVE
  BANK
  OTHER
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("expense_category")
}

model Expense {
  id            String               @id @default(cuid())
  // Jour civil de la dépense (cohérent avec Order.dailyDate pour les requêtes
  // de plage dans les stats).
  date          DateTime             @db.Date
  amount        Int // montant en francs CFA
  paymentMethod ExpensePaymentMethod @default(CASH)
  supplier      String?
  note          String?
  // Justificatif (photo) optionnel : chemin /uploads/receipts/... ou URL http(s).
  receiptUrl    String?

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@index([categoryId])
  @@map("expense")
}

model CashClosing {
  id          String   @id @default(cuid())
  // Un jour civil = une clôture (cohérent avec Order.dailyDate / Expense.date).
  date        DateTime @unique @db.Date
  openingFloat Int     @default(0) // fond de caisse (FCFA)
  countedCash  Int     @default(0) // espèces comptées en fin de journée

  // Instantané calculé au moment de la clôture (les commandes/dépenses peuvent
  // évoluer ensuite — on fige ce que le système indiquait).
  cashSales    Int @default(0) // ventes encaissées en espèces ce jour
  cashExpenses Int @default(0) // dépenses payées en espèces ce jour
  expectedCash Int @default(0) // openingFloat + cashSales - cashExpenses
  difference   Int @default(0) // countedCash - expectedCash

  note String?

  closedById String?
  closedBy   User?   @relation("CashClosingClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("cash_closing")
}
